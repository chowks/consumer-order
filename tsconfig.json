{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "paths": {
      "@/*": ["./src/*"],
      "@generated/*": ["./generated/*"]
    },
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "esbuild.config.ts"],
  "exclude": ["node_modules", "dist", "generated"]
}
